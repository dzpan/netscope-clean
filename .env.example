# =============================================================================
# NetScope Configuration
# =============================================================================
# Copy to .env and modify as needed. All variables are optional — sensible
# defaults are used when unset.

# --- Server ---
# NETSCOPE_LOG_LEVEL=info              # debug | info | warning | error | critical
# NETSCOPE_DEBUG=false                 # Enable OpenAPI docs at /api/docs

# --- Sessions ---
# NETSCOPE_MAX_SESSIONS=50            # Max concurrent topology sessions (1-1000)

# --- Frontend ---
# NETSCOPE_STATIC_DIR=frontend/dist   # Path to built Vue frontend assets

# --- CORS (development only) ---
# NETSCOPE_CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# --- Persistence (optional — in-memory LRU used when unset) ---
# NETSCOPE_DB_PATH=/data/netscope.db  # SQLite database path for session persistence

# --- Auto-Rediscovery (requires NETSCOPE_DB_PATH) ---
# NETSCOPE_REDISCOVERY_INTERVAL=0     # Seconds between auto re-discovery runs (0=disabled)

# --- Data Retention ---
# NETSCOPE_SNAPSHOT_RETENTION_DAYS=90  # Delete snapshots older than N days (0=keep forever)
